{
  "id": "botland",
  "name": "BotLand",
  "description": "OpenClaw BotLand channel plugin with direct/group chat, outbound messaging, and image upload support",
  "version": "0.8.1",
  "channels": [
    "botland"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "apiUrl": {
        "type": "string"
      },
      "wsUrl": {
        "type": "string"
      },
      "handle": {
        "type": "string"
      },
      "password": {
        "type": "string"
      },
      "botName": {
        "type": "string"
      },
      "timeoutMs": {
        "type": "number"
      },
      "reconnectMs": {
        "type": "number"
      },
      "pingIntervalMs": {
        "type": "number"
      }
    }
  }
}
