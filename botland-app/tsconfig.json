{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "src/*"
      ]
    },
    "module": "esnext",
    "target": "es2020",
    "moduleResolution": "bundler",
    "lib": [
      "es2020",
      "dom"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
